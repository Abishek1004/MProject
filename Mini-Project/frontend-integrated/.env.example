# ─── Frontend Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local for local development
# On Render/Netlify, set these in the environment variables section of your service

# Spring Boot Backend URL (without trailing slash)
VITE_API_BASE_URL=https://your-spring-backend.onrender.com/api

# Node.js Admin Backend URL (without trailing slash)
VITE_NODE_API_URL=https://your-node-backend.onrender.com/api

# Prediction Services (optional — only needed if you deploy these)
VITE_LAPTOP_PREDICT_URL=https://your-laptop-flask.onrender.com/predict
VITE_TABLET_PREDICT_URL=https://your-tablet-flask.onrender.com/predict
VITE_YOLO_URL=https://your-yolo-flask.onrender.com/predict-image
